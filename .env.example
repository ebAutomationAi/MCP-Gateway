# MCP Server Configuration
# Command to run the MCP server
MCP_COMMAND=npx
# Arguments for the MCP server (space-separated)
# Example — GitHub MCP server:
#   MCP_ARGS=-y @modelcontextprotocol/server-github
#   GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here
# Example — Filesystem MCP server:
#   MCP_ARGS=-y @modelcontextprotocol/server-filesystem /path/to/dir
MCP_ARGS=

# Server Configuration
PORT=3001

# API Authentication — generate with: openssl rand -hex 32
API_TOKEN=your_secure_api_token_here

# Ngrok (only needed for public exposure via docker-compose)
NGROK_AUTHTOKEN=your_ngrok_auth_token_here
