# GitHub MCP Server Configuration
# Personal Access Token (classic) with scopes: repo, read:org, read:user
GITHUB_TOKEN=your_github_pat_token_here

# Ngrok Configuration (only needed for public exposure via docker-compose)
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# Server Configuration
PORT=3001

# API Authentication (optional — if unset, auth is disabled / dev mode)
# Generate with: openssl rand -hex 32
API_TOKEN=your_secure_api_token_here
